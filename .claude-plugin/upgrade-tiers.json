{
  "_comment": "plugin-cache lists subtrees authoritative in the plugin; never projected to hosts. Consumers read via cpf_resolve_asset. See ADR-003.",
  "tiers": {
    "customizable": [".cpf/policy.json"],
    "overwrite": [
      ".cpf/scripts/hooks/pre-commit",
      ".cpf/scripts/hooks/commit-msg",
      ".cpf/scripts/install-hooks.sh",
      ".markdownlint-cli2.yaml",
      ".prettierignore",
      ".specify/doctor-registry.json",
      ".cpf/scripts/doctor.sh",
      ".specify/proposals/.gitkeep",
      ".github/workflows/ci-base.yml",
      "ci/gitlab/gitlab-ci-base.yml"
    ],
    "review": [
      ".github/workflows/release.yml",
      ".github/workflows/codeql.yml",
      ".github/CODEOWNERS",
      ".github/dependabot.yml",
      ".github/PULL_REQUEST_TEMPLATE.md",
      ".github/ISSUE_TEMPLATE/bug_report.yml",
      ".github/ISSUE_TEMPLATE/config.yml",
      ".github/ISSUE_TEMPLATE/feature_request.yml",
      "Jenkinsfile",
      ".prettierrc.json",
      "ci/github/repo-settings.md",
      "ci/github/CODEOWNERS.template",
      "ci/github/dependabot.yml",
      "ci/github/PULL_REQUEST_TEMPLATE.md",
      "ci/github/workflows/commit-standards.yml",
      ".gitlab/merge_request_templates/Default.md"
    ],
    "skip": [
      ".github/workflows/ci.yml",
      ".gitlab-ci.yml",
      "CLAUDE.md",
      ".specify/memory/*",
      ".specify/specs/*",
      ".specify/proposals/*",
      "feature_list.json",
      "claude-progress.txt",
      "README.md",
      ".gitignore",
      "init.sh",
      ".cpf/overrides/",
      ".cpf/upstream-cache/"
    ],
    "plugin-cache": [
      ".specify/templates/",
      ".specify/WORKFLOW.md",
      "prompts/",
      "ci/principles/",
      "ci/gitlab/",
      "ci/jenkins/",
      "CLAUDE.md.template"
    ]
  }
}
